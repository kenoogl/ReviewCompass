{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "evidence_register",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "artifact_ref",
          "source_analysis_manifest_ref",
          "input_run_set_ref",
          "evidence_class",
          "review_mode",
          "maturity_label",
          "stale",
          "generated_at"
        ],
        "properties": {
          "evidence_id": {"type": "string"},
          "artifact_ref": {"$ref": "#/$defs/artifact_ref"},
          "source_analysis_manifest_ref": {"$ref": "#/$defs/artifact_ref"},
          "input_run_set_ref": {"$ref": "#/$defs/artifact_ref"},
          "evidence_class": {
            "type": "string",
            "enum": ["valid", "invalid", "exploratory", "analysis_blocked"]
          },
          "review_mode": {
            "type": "string",
            "enum": [
              "manual_dogfooding",
              "runtime_mediated",
              "subagent_mediated",
              "api_mediated"
            ]
          },
          "maturity_label": {
            "type": "string",
            "enum": ["mature", "preliminary", "exploratory"]
          },
          "caveat_refs": {
            "type": "array",
            "items": {"$ref": "#/$defs/artifact_ref"}
          },
          "supersedes": {
            "type": "array",
            "items": {"$ref": "#/$defs/artifact_ref"}
          },
          "superseded_by": {
            "type": "array",
            "items": {"$ref": "#/$defs/artifact_ref"}
          },
          "stale": {"type": "boolean"},
          "stale_reason": {"type": "string"},
          "stale_source_ref": {"$ref": "#/$defs/artifact_ref"},
          "generated_at": {"type": "string"}
        },
        "allOf": [
          {
            "if": {
              "properties": {"stale": {"const": true}},
              "required": ["stale"]
            },
            "then": {"required": ["stale_reason", "stale_source_ref"]}
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "required": ["ref_type", "target_path"],
      "properties": {
        "ref_type": {"type": "string"},
        "target_path": {"type": "string"},
        "target_id": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

