{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "intake_failure_report",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "failure_id",
          "intake_failure_reason",
          "source_path",
          "affected_destinations",
          "detected_at",
          "failure_kind"
        ],
        "properties": {
          "failure_id": {"type": "string"},
          "intake_failure_reason": {
            "type": "string",
            "enum": [
              "upstream_evaluation_missing",
              "upstream_evaluation_unreadable",
              "upstream_evaluation_stale",
              "conformance_evaluation_missing"
            ]
          },
          "source_path": {"type": "string"},
          "affected_destinations": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["dashboard", "weekly", "audit", "reports"]
            }
          },
          "detected_at": {"type": "string"},
          "failure_kind": {
            "type": "string",
            "enum": ["missing", "unreadable", "stale"]
          },
          "missing_artifact_refs": {
            "type": "array",
            "items": {"$ref": "#/$defs/artifact_ref"}
          },
          "recommended_action": {"type": "string"},
          "detail": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "required": ["ref_type", "target_path"],
      "properties": {
        "ref_type": {"type": "string"},
        "target_path": {"type": "string"},
        "target_id": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
