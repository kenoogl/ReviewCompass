{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "$defs": {
    "count_map": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "findings_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_severity"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "by_severity": {
          "$ref": "#/$defs/count_map"
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_type", "target_path"],
      "properties": {
        "ref_type": {
          "type": "string"
        },
        "target_path": {
          "type": "string"
        },
        "target_id": {
          "type": ["string", "null"]
        }
      }
    }
  },
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["feature", "review_mode", "findings_summary", "target"],
        "properties": {
          "feature": {
            "type": "string"
          },
          "review_mode": {
            "type": "string"
          },
          "findings_summary": {
            "$ref": "#/$defs/findings_summary"
          },
          "target": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifact_ref"
            }
          }
        }
      }
    }
  }
}
