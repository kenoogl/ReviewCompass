{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewcompass.local/schemas/workflow/model-assignment-cost.schema.json",
  "title": "Model Assignment Cost",
  "description": "review-run の role assignment、elapsed time、retry count、token usage、API cost、finding contribution を同じ粒度で記録する D-019 schema。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "nullableNonNegativeInteger": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "nullableNonNegativeNumber": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:).+"
    },
    "sourceState": {
      "type": "string",
      "enum": [
        "provider_reported",
        "estimated",
        "missing"
      ]
    }
  },
  "required": [
    "event_type",
    "run_id",
    "schema_version",
    "source_ref",
    "role_assignments",
    "summary"
  ],
  "properties": {
    "event_type": {
      "const": "model_assignment_cost"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "source_ref": {
      "$ref": "#/$defs/relativePath"
    },
    "role_assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "provider",
          "model_id",
          "invocation_path",
          "attempts",
          "retry_count",
          "duration_seconds",
          "token_usage",
          "api_cost",
          "contribution"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "attempts": {
                  "const": 1
                }
              },
              "required": [
                "attempts"
              ]
            },
            "then": {
              "properties": {
                "retry_count": {
                  "const": 0
                }
              }
            }
          }
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "model_id": {
            "type": "string",
            "minLength": 1
          },
          "invocation_path": {
            "$ref": "#/$defs/relativePath"
          },
          "attempts": {
            "type": "integer",
            "minimum": 1
          },
          "retry_count": {
            "$ref": "#/$defs/nonNegativeInteger"
          },
          "duration_seconds": {
            "$ref": "#/$defs/nonNegativeNumber"
          },
          "token_usage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "prompt_tokens",
              "completion_tokens",
              "total_tokens",
              "source"
            ],
            "properties": {
              "prompt_tokens": {
                "$ref": "#/$defs/nullableNonNegativeInteger"
              },
              "completion_tokens": {
                "$ref": "#/$defs/nullableNonNegativeInteger"
              },
              "total_tokens": {
                "$ref": "#/$defs/nullableNonNegativeInteger"
              },
              "source": {
                "$ref": "#/$defs/sourceState"
              }
            }
          },
          "api_cost": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "amount",
              "currency",
              "source"
            ],
            "properties": {
              "amount": {
                "$ref": "#/$defs/nullableNonNegativeNumber"
              },
              "currency": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3
              },
              "source": {
                "$ref": "#/$defs/sourceState"
              }
            }
          },
          "contribution": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "findings_reported",
              "findings_accepted",
              "findings_rejected"
            ],
            "properties": {
              "findings_reported": {
                "$ref": "#/$defs/nonNegativeInteger"
              },
              "findings_accepted": {
                "$ref": "#/$defs/nonNegativeInteger"
              },
              "findings_rejected": {
                "$ref": "#/$defs/nonNegativeInteger"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_duration_seconds",
        "total_retry_count",
        "total_api_cost",
        "cost_completeness",
        "token_completeness"
      ],
      "properties": {
        "total_duration_seconds": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "total_retry_count": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "total_api_cost": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "cost_completeness": {
          "type": "string",
          "enum": [
            "complete",
            "partial",
            "missing"
          ]
        },
        "token_completeness": {
          "type": "string",
          "enum": [
            "complete",
            "partial",
            "missing"
          ]
        }
      }
    }
  }
}
