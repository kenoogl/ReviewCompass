{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewcompass.local/schemas/self-improvement/carry-forward-register.schema.json",
  "title": "Self Improvement Carry-forward Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "register_id",
    "schema_version",
    "source_type",
    "items"
  ],
  "properties": {
    "register_id": {
      "type": "string",
      "const": "carry-forward-register"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "source_type": {
      "type": "string",
      "const": "carry_forward_register"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "scope",
          "source_feature",
          "target_feature_or_phase",
          "finding_summary",
          "status",
          "decision_needed",
          "decision_reasons",
          "carry_forward_reason",
          "resolution",
          "evidence_refs",
          "project_local_context"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "pattern": "^carry-forward-[0-9]{3,}$"
          },
          "scope": {
            "type": "string",
            "enum": [
              "cross_scope",
              "upstream_reopen",
              "project_local"
            ]
          },
          "source_feature": {
            "type": [
              "string",
              "null"
            ]
          },
          "target_feature_or_phase": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "finding_summary": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "resolved",
              "deferred"
            ]
          },
          "decision_needed": {
            "type": "boolean"
          },
          "decision_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "carry_forward_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "path"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              }
            }
          },
          "project_local_context": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
