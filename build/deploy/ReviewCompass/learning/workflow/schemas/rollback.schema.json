{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewcompass.local/schemas/self-improvement/rollback.schema.json",
  "title": "Self Improvement Rollback Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rollback_id",
    "target_proposal_id",
    "rollback_method",
    "rollback_reason",
    "rollback_date",
    "related_artifacts"
  ],
  "properties": {
    "rollback_id": {
      "type": "string",
      "pattern": "^RB-[0-9]{3,}$"
    },
    "target_proposal_id": {
      "type": "string",
      "pattern": "^WP-[0-9]{3,}$"
    },
    "rollback_method": {
      "type": "string",
      "enum": [
        "archive_restoration",
        "status_downgrade",
        "git_revert"
      ]
    },
    "rollback_reason": {
      "type": "string",
      "minLength": 1
    },
    "rollback_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "related_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
