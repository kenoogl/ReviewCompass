{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewcompass.local/schemas/self-improvement/signal.schema.json",
  "title": "Self Improvement Signal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signal_id",
    "signal_type",
    "observed_pattern",
    "related_disciplines",
    "proposed_proposal_type",
    "motivating_evidence_seed"
  ],
  "required_for_obsolete_or_conflict": [
    "related_disciplines"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "pattern": "^SE-[0-9]{3,}$"
    },
    "signal_type": {
      "type": "string",
      "enum": [
        "discipline_absence",
        "discipline_violation",
        "discipline_obsolete",
        "discipline_conflict"
      ]
    },
    "observed_pattern": {
      "type": "string",
      "minLength": 1
    },
    "related_disciplines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_proposal_type": {
      "type": "string",
      "enum": [
        "new_discipline",
        "update",
        "archive",
        "consolidation"
      ]
    },
    "motivating_evidence_seed": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
