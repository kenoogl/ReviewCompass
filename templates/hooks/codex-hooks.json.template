{
  "_comment": "対象アプリの .codex/hooks.json の雛形。pre-bash-precheck は Claude/Codex 共通、session-record-capture-current-on-todo と session-record-promote-previous-draft は Codex 専用。",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/review-prompt-guide-inject.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/session-record-promote-previous-draft.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/session-record-capture-current-on-todo.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/pre-bash-precheck.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
