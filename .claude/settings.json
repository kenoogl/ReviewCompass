{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -m unittest tests.tools.*)",
      "Bash(python3 -m unittest tests.hooks.*)",
      "Bash(python3 -m unittest discover -s tests*)",
      "Bash(zsh -c 'source ~/.zshrc && .venv/bin/python3 tools/api_providers/run_role.py *')",
      "Bash(.venv/bin/python3 tools/api_providers/run_review.py *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-precheck.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-record-capture-previous.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-record-capture.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
