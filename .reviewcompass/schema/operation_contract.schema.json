{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:reviewcompass:schema:operation_contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "operation_id",
    "required_action",
    "effect_kind",
    "approval_required",
    "approval_contract_refs",
    "phase_boundary",
    "sequence",
    "actor",
    "branching",
    "max_effect_kind",
    "preconditions",
    "postconditions",
    "side_effects",
    "commit_boundary",
    "workflow_state_effect",
    "canonical_invocation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "required_action": {
      "$ref": "required_action.schema.json"
    },
    "effect_kind": {
      "$ref": "effect_kind.schema.json"
    },
    "approval_required": {
      "type": "boolean"
    },
    "approval_contract_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "phase_boundary": {
      "$ref": "phase_boundary.schema.json"
    },
    "sequence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "internal_steps"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "parallel_ok",
            "serial_only"
          ]
        },
        "internal_steps": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind",
        "source"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "llm",
            "proxy_model",
            "tool",
            "mixed"
          ]
        },
        "source": {
          "type": "string"
        }
      }
    },
    "branching": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "has_branches",
        "branches"
      ],
      "properties": {
        "has_branches": {
          "type": "boolean"
        },
        "branches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "branch_id",
              "condition",
              "internal_steps",
              "max_effect_kind",
              "approval_aggregation",
              "human_only_override_applies",
              "precondition_ids",
              "postcondition_ids"
            ],
            "properties": {
              "branch_id": {
                "type": "string"
              },
              "condition": {
                "type": "string"
              },
              "internal_steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": [
                    "step_id",
                    "effect_kind",
                    "approval_required",
                    "approval_contract_ref",
                    "phase_boundary",
                    "source_ref"
                  ],
                  "properties": {
                    "step_id": {
                      "type": "string"
                    },
                    "effect_kind": {
                      "$ref": "effect_kind.schema.json"
                    },
                    "approval_required": {
                      "type": "boolean"
                    },
                    "approval_contract_ref": {
                      "type": "string"
                    },
                    "phase_boundary": {
                      "$ref": "phase_boundary.schema.json"
                    },
                    "source_ref": {
                      "type": "string"
                    }
                  }
                }
              },
              "max_effect_kind": {
                "$ref": "effect_kind.schema.json"
              },
              "approval_aggregation": {
                "type": "string"
              },
              "human_only_override_applies": {
                "type": "boolean"
              },
              "precondition_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "postcondition_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "max_effect_kind": {
      "$ref": "effect_kind.schema.json"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "side_effects": {
      "type": "array"
    },
    "commit_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        }
      }
    },
    "workflow_state_effect": {
      "type": "object"
    },
    "canonical_invocation": {
      "type": "object"
    }
  }
}
