{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:reviewcompass:schema:proxy_triage_decision",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "decision_id",
    "target_findings",
    "target_clusters",
    "source_triage_path",
    "raw_response_path",
    "parsed_finding_paths",
    "decision_prompt_path",
    "proxy_raw_response_path",
    "candidate_decisions",
    "selected_decision",
    "reasoning_summary",
    "final_application_target",
    "approval_scope",
    "evidence_completeness",
    "finding_operation_map",
    "approval_gate_record_refs",
    "operation_contract_refs",
    "review_wave_impact_evidence",
    "evidence_conflicts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "proxy-triage-decision-v1"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "target_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_clusters": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_triage_path": {
      "type": "string",
      "minLength": 1
    },
    "raw_response_path": {
      "type": "string",
      "minLength": 1
    },
    "parsed_finding_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_prompt_path": {
      "type": "string",
      "minLength": 1
    },
    "proxy_raw_response_path": {
      "type": "string",
      "minLength": 1
    },
    "candidate_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/finding_decision"
      }
    },
    "selected_decision": {
      "$ref": "#/$defs/finding_decision"
    },
    "reasoning_summary": {
      "type": "string",
      "minLength": 1
    },
    "final_application_target": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "operation_id",
        "triage_path",
        "finding_ids"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "minLength": 1
        },
        "triage_path": {
          "type": "string",
          "minLength": 1
        },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "approval_scope": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "review_triage_decide",
        "apply_fixes"
      ],
      "properties": {
        "review_triage_decide": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "apply_fixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "operation_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_completeness": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "raw_response",
        "parsed_findings",
        "source_triage",
        "approval_gate",
        "operation_contract",
        "review_wave_impact"
      ],
      "properties": {
        "raw_response": {"type": "boolean"},
        "parsed_findings": {"type": "boolean"},
        "source_triage": {"type": "boolean"},
        "approval_gate": {"type": "boolean"},
        "operation_contract": {"type": "boolean"},
        "review_wave_impact": {"type": "boolean"}
      }
    },
    "finding_operation_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["finding_id", "operation_id"],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "operation_id": {"type": "string", "minLength": 1}
        }
      }
    },
    "approval_gate_record_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "operation_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "review_wave_impact_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "evidence_refs"],
      "properties": {
        "status": {"type": "string", "minLength": 1},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "evidence_conflicts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "finding_decision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "final_label",
        "finding_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "final_label": {
          "type": "string",
          "minLength": 1
        },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
