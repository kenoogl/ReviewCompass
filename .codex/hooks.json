{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/review-prompt-guide-inject.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/session-record-promote-previous-draft.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/session-record-capture-current-on-todo.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/pre-bash-precheck.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
