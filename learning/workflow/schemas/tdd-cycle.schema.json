{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewcompass.local/schemas/workflow/tdd-cycle.schema.json",
  "title": "TDD Cycle Evidence",
  "description": "review finding が failing test へ変換され、implementation で green になったことを記録する event schema。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "commitHash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:).+"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "failedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "exit_code",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "failed"
        },
        "exit_code": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "passedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "exit_code",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "passed"
        },
        "exit_code": {
          "type": "integer",
          "const": 0
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "required": [
    "event_type",
    "cycle_id",
    "linked_finding_ids",
    "test_first_commit",
    "implementation_commit",
    "failing_test_command",
    "failing_test_result",
    "green_test_command",
    "green_test_result",
    "changed_files"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "const": "tdd_cycle"
    },
    "cycle_id": {
      "type": "string",
      "pattern": "^TDD-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3,}$"
    },
    "linked_finding_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "test_first_commit": {
      "$ref": "#/$defs/commitHash"
    },
    "implementation_commit": {
      "$ref": "#/$defs/commitHash"
    },
    "failing_test_command": {
      "$ref": "#/$defs/command"
    },
    "failing_test_result": {
      "$ref": "#/$defs/failedResult"
    },
    "green_test_command": {
      "$ref": "#/$defs/command"
    },
    "green_test_result": {
      "$ref": "#/$defs/passedResult"
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
