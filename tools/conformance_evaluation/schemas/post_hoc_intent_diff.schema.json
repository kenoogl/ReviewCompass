{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post-hoc intent difference candidate",
  "type": "object",
  "required": [
    "feature",
    "phase",
    "classification",
    "code_refs",
    "existing_spec_refs",
    "reasoning_summary",
    "needs_human_decision"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "feature": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": [
        "requirements",
        "design",
        "tasks",
        "implementation"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "existing_sufficient",
        "spec_update_candidate",
        "design_conflict_candidate",
        "downstream_impact_candidate",
        "implementation_change_candidate"
      ]
    },
    "code_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "existing_spec_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "reasoning_summary": {
      "type": "string"
    },
    "needs_human_decision": {
      "type": "boolean"
    },
    "handoff_target": {
      "type": "string"
    },
    "write_policy": {
      "type": "string",
      "enum": [
        "handoff_only"
      ]
    }
  },
  "additionalProperties": true
}
