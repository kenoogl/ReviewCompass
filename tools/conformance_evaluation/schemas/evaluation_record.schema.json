{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conformance Evaluation Record Front Matter",
  "type": "object",
  "required": [
    "type",
    "mode_internal",
    "author",
    "reviewer",
    "target_commit",
    "related_artifacts"
  ],
  "properties": {
    "type": {
      "const": "conformance_evaluation"
    },
    "mode_internal": {
      "enum": [
        "generation",
        "check",
        "post_hoc_intent_diff",
        "completed_followup_conformance",
        "completed_followup_contract_confirmation"
      ]
    },
    "author": {
      "type": ["string", "object"]
    },
    "reviewer": {
      "type": ["string", "object"]
    },
    "target_commit": {
      "type": "string",
      "minLength": 1
    },
    "related_artifacts": {
      "type": "object",
      "properties": {
        "runtime": {},
        "evaluation": {},
        "workflow_management": {},
        "self_improvement": {}
      }
    }
  },
  "additionalProperties": true
}
